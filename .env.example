# MarketingOS configuration
#
# By default MarketingOS runs on the Claude Agent SDK, which uses the SAME login
# as Claude Code. If you're already logged into Claude Code (your Pro/Max
# subscription), you DO NOT need an API key — just leave this file as-is or skip it.
#
# Optional: set a key only if you want to bill against the Anthropic API instead
# of your subscription. The SDK will pick it up automatically if present.
# ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are used if left blank).
# MODEL_OPUS=claude-opus-4-8
# MODEL_SONNET=claude-sonnet-4-6
# MODEL_HAIKU=claude-haiku-4-5

# Optional: crawler settings
# CRAWL_RENDER=1        # 1 = render pages in headless Chromium (default); 0 = fast HTTP-only
# CRAWL_MAX_PAGES=12
# CRAWL_TIMEOUT_MS=15000

# Optional: institutional settings
# RESEARCH_WEB=1        # 1 = agents use real web search for cited evidence (default); 0 = model-only
# QA_THRESHOLD=80       # min QA score (0-100) before a deliverable is re-run with fixes

# Optional: performance
# MOS_CONCURRENCY=3     # how many independent agents run in parallel (1 = fully serial)
